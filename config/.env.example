# Environment variables for sensitive data
# Copy this file to .env and fill in actual values
# Do NOT commit the .env file to version control

# RPC Configuration
RPC_URL=http://localhost:8545
RPC_API_KEY=your_api_key_here

# LanceDB Configuration (Local)
LANCEDB_PATH=./lancedb

# ============================================
# Object Store Configuration (Optional)
# ============================================

# AWS S3 Configuration
# Uncomment and configure if using S3 storage (db_path: s3://bucket/path)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_SESSION_TOKEN=  # Optional, for temporary credentials
# AWS_ENDPOINT=  # Optional, for S3-compatible stores like MinIO (e.g., http://localhost:9000)

# Google Cloud Storage Configuration
# Uncomment if using GCS storage (db_path: gs://bucket/path)
# GOOGLE_SERVICE_ACCOUNT=/path/to/service-account.json

# Azure Blob Storage Configuration
# Uncomment if using Azure storage (db_path: az://container/path)
# AZURE_STORAGE_ACCOUNT_NAME=your_account_name
# AZURE_STORAGE_ACCOUNT_KEY=your_account_key
